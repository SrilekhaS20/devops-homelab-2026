pipeline {
    agent any
    
    tools {
        maven 'Maven-3.9'
    }
    
    environment {
        APP_NAME = 'java-app'
    }
    
    stages {
        stage('Build JAR with Maven') {
            steps {
                echo "Building JAR file with Maven"
                dir('Day-5/java-cicd') {
                    sh '''
                      mvn --version
                      mvn clean package
                      ls -lh target/
                    '''
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo "Using Eclipse Temurin (OpenJDK replacement)"
                dir('Day-5/java-cicd') {
                    sh '''
                        docker build -t ${APP_NAME}:${BUILD_NUMBER} .
                        docker images | grep ${APP_NAME}

                        echo "Image size:"
                        docker images ${APP_NAME}:${BUILD_NUMBER} --format "{{.Size}}"
                    '''
                }
            }
        }

        stage('Deploy container') {
            steps {
                echo "Deploying container"
                sh '''
                    # Stop old container (if exists)
                    # 2>/dev/null: Suppress error messages
                    # || true: Don't fail if container doesn't exist
                    docker stop ${APP_NAME} 2>/dev/null || true
                    docker rm ${APP_NAME} 2>/dev/null || true

                    docker run -d -p 8081:8080 --name ${APP_NAME} ${APP_NAME}:${BUILD_NUMBER}

                    # Wait for Spring Boot to start
                    sleep 30
                    
                    docker ps | grep ${APP_NAME}
                    echo "Container is running!"
                '''
            }
        }

        stage('Test Application') {
            steps {
                echo "Testing Application"
                sh '''
                    echo "Test1: Home page"
                    docker exec ${APP_NAME} curl -f http://localhost:8080

                    echo "Test2: Hello endpoint"
                    docker exec ${APP_NAME} curl -f http://localhost:8080/api/hello

                    echo "Test3: Health endpoint"
                    docker exec ${APP_NAME} curl -f http://localhost:8080/api/health

                    echo "All Tests passed!"
                '''
            }
        }
    }

    post {
        success {
            echo '========================================'
            echo 'STAGE1 PIPELINE SUCCESS'
            echo '========================================'
            echo "Application url: http://192.168.1.9:8081"
            echo "Build: ${BUILD_NUMBER}"
            echo "Image: eclipse-temurin:17-jdk"
            echo "========================================"
        }

        failure {
            sh 'docker logs ${APP_NAME} || true'
        }

        always {
            sh 'docker image prune -f || true'
        }
    }
}